# =============================================================================
# Frontend — local development
# Copy to .env.local and adjust values.
# =============================================================================

# -----------------------------------------------------------------------------
# API routing
# -----------------------------------------------------------------------------

# Direct backend URL (server-side rewrites in dev, documentation reference)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Browser-facing API base — `/api` routes through Next.js dev proxy (recommended)
NEXT_PUBLIC_CLIENT_API_URL=/api

# Server-only backend URL (optional override for Docker / SSR)
# API_URL=http://api:8000/api

# Force Next.js rewrites in production (default: nginx handles /api)
# USE_NEXT_REWRITES=false

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------

# Public site URL (metadata, OG tags, absolute links)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics (disabled by default)
# NEXT_PUBLIC_ENABLE_ANALYTICS=false

# -----------------------------------------------------------------------------
# Build / runtime
# -----------------------------------------------------------------------------

# Disable Next.js telemetry in CI and Docker
# NEXT_TELEMETRY_DISABLED=1

# Node environment (set automatically by Next.js)
# NODE_ENV=development
