# =============================================================================
# Frontend — production deployment
# Copy to .env.production or pass as Docker build-args / runtime env.
# =============================================================================

# -----------------------------------------------------------------------------
# Build-time (inlined into client bundle — set before `npm run build`)
# -----------------------------------------------------------------------------

# Browser calls same-origin /api (nginx proxies to backend)
NEXT_PUBLIC_CLIENT_API_URL=/api

# External API URL (used if client cannot use relative /api)
NEXT_PUBLIC_API_URL=https://api.example.com/api

# Canonical public URL
NEXT_PUBLIC_SITE_URL=https://app.example.com

# Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Disable telemetry
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# Runtime (Docker / Node server — not exposed to browser)
# -----------------------------------------------------------------------------

# Internal backend URL for optional Next.js rewrites (nginx preferred)
API_URL=http://api:8000/api

# Use Next.js rewrites instead of nginx /api proxy (not recommended with nginx)
USE_NEXT_REWRITES=false

# Node
NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=3000

# -----------------------------------------------------------------------------
# Nginx (docker-compose.prod.yml)
# -----------------------------------------------------------------------------

# FRONTEND_HOST=frontend
# FRONTEND_PORT=3000
# API_HOST=api
# API_PORT=8000
# NGINX_SERVER_NAME=app.example.com
